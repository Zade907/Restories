# =============================================================
# Reddit Shorts Factory - Environment Configuration
# Copy this file to .env and fill in your API keys
# =============================================================

# --- LLM API Keys ---
# Gemini: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# OpenRouter (free tier): https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# --- YouTube API ---
# Setup: https://console.cloud.google.com/
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secrets.json
YOUTUBE_CREDENTIALS_FILE=config/youtube_credentials.json

# --- Optional: Additional Services ---
# ElevenLabs TTS (optional premium)
ELEVENLABS_API_KEY=

# --- App Settings ---
APP_ENV=development
LOG_LEVEL=INFO
